{
  "version": 2,
  "routes": [
    {
      "src": "/(fr|en|ar)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    },
    {
      "src": "/(?!fr|en|ar|api|_next|favicon.ico|.*\\.(png|jpg|jpeg|gif|svg|webp|css|js|json|ico|txt))(?<path>.*)",
      "dest": "/fr/404",
      "status": 404
    }
  ],
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ]
}
